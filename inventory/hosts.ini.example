[servers]
# Replace with your server details
# 192.168.1.100 ansible_user=root ansible_ssh_private_key_file=~/.ssh/id_ed25519 ansible_python_interpreter=/usr/bin/python3

[openwrt]
# OpenWrt routers — Python is NOT pre-installed, so we use /usr/bin/python3 from opkg
# Run: opkg update && opkg install python3 on the router first
# 192.168.1.1 ansible_user=root ansible_python_interpreter=/usr/bin/python3
